VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_VERIFIED_DOMAIN=midnightcorp.click
VITE_APP_URL=http://localhost:3000

# Opcional: captcha en OTP (Cloudflare Turnstile)
#   Site key (público) — pegar aquí. Si está vacío, el captcha se omite.
#   El secret key (privado) va en Supabase Dashboard → Auth → Captcha protection.
VITE_TURNSTILE_SITE_KEY=

# ─────────────────────────────────────────────────────────────
# Server-side only (Supabase Edge Functions Secrets, NO en frontend):
#
# Bold (pagos):
#   RESEND_API_KEY            → para enviar tickets desde send-ticket-email
#   BOLD_SECRET_KEY           → llave de integridad Bold (signature SHA-256)
#   BOLD_WEBHOOK_SECRET       → secret HMAC para verificar firma del webhook
#                              (puede ser igual a BOLD_SECRET_KEY si Bold no
#                              soporta secret separado)
#   BOLD_WEBHOOK_REQUIRE_SIGNATURE=true   → en producción, fuerza rechazo si
#                              la firma del webhook es inválida o ausente
#   BOLD_API_KEY              → key para consultar transacciones (bold-reconcile)
#   SUPABASE_SERVICE_ROLE_KEY → inyectado automáticamente por Supabase
#
# Google Wallet (opcional, para botón "Add to Google Wallet"):
#   Configurar en: https://pay.google.com/business/console
#   GOOGLE_WALLET_ISSUER_ID                 → ID asignado tras crear cuenta
#   GOOGLE_WALLET_CLASS_ID                  → Event ticket class creada via API
#   GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL     → email del service account (xxx@xxx.iam.gserviceaccount.com)
#   GOOGLE_WALLET_PRIVATE_KEY               → private_key del JSON del SA (formato PEM con \n literales)
#
# Apple Wallet (opcional, para botón "Add to Apple Wallet"):
#   Requiere Apple Developer Program ($99/año) + Pass Type ID
#   APPLE_PASS_TYPE_ID                      → "pass.com.midnightcorp.ticket"
#   APPLE_PASS_TEAM_ID                      → tu Team ID (10 chars)
#   APPLE_PASS_CERT_P12_BASE64              → cert .p12 exportado, en base64
#   APPLE_PASS_CERT_PASSWORD                → password del .p12
#
# QR dinámico anti-reventa (recomendado activar antes del lanzamiento):
#   QR_HMAC_SECRET            → string aleatorio largo (≥32 chars, ej. `openssl rand -base64 48`)
#   QR_WINDOW_SECONDS=60      → ventana de validez del token (default 60s)
#   Mientras no se configure, el QR sigue siendo estático (order_number) y
#   el flujo funciona en modo backward-compat con tickets viejos.
# ─────────────────────────────────────────────────────────────
